# selvr.toml — Selvr package manifest
# Copy to selvr.toml and edit as needed.
# Run `selvr init` to generate this file automatically.

[package]
name        = "my-selvr-app"
version     = "0.1.0"
authors     = ["Your Name <you@example.com>"]
license     = "MIT"
description = "A fast, browser-native Selvr application"
homepage    = "https://example.com"
repository  = "https://github.com/you/my-selvr-app"
keywords    = ["selvr", "web", "wasm"]

# ── Dependencies ──────────────────────────────────────────────────────────────
# Use `selvr add <name>` to add dependencies.
# Version requirements follow semver: "^1.0.0" means >=1.0.0 <2.0.0.

[dependencies]
selvr-std  = "1.0.0"   # official standard library
selvr-dom  = "^0.1.0"  # DOM utilities

# A local path dependency (for monorepos / active development):
# my-utils = { version = "*", path = "../my-utils" }

# ── Dev dependencies (only used during `selvr test`) ──────────────────────────
[dev-dependencies]
selvr-test = "1.0.0"

# ── Build configuration ───────────────────────────────────────────────────────
[build]
# emit = "js"      — transpile to a single .js file (default, Phase 1)
# emit = "hybrid"  — split into .wasm + .js + .loader.js (Phase 2.5)
emit  = "hybrid"
opt   = "release"   # "debug" | "release"
entry = "src/main.self"

# ── Targeting overrides ───────────────────────────────────────────────────────
# Override the compiler's automatic WASM/JS routing for specific functions.
# Equivalent to adding #[wasm] / #[js] attributes in the source.
# Most projects don't need this — let the compiler decide.

[targets]
force_wasm = ["heavy_compute", "matmul", "sieve"]
force_js   = ["render_frame", "on_click", "fetch_data"]
